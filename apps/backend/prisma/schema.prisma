generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model WorkType {
  id Int @id @default(autoincrement())
  name String @unique
  unit String
  entries Entry[]
}

model Entry {
  id Int @id @default(autoincrement())
  date DateTime
  workTypeId Int
  workType WorkType @relation(fields: [workTypeId], references: [id])
  volume Float
  executorName String
  notes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
